# ── Supabase (обязательно) ─────────────────────────────────────────
# Project URL и service_role ключ из Project Settings → API.
# Оба используются ТОЛЬКО на сервере, поэтому без префикса NEXT_PUBLIC_.
# service_role ключ СЕКРЕТНЫЙ — никогда не коммитьте реальное значение.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Бизнес-зона (обязательно) ──────────────────────────────────────
# Таймзона, в которой заданы рабочие часы (working_hours).
# Слоты пользователю показываются в его зоне, но генерируются в этой.
BUSINESS_TIMEZONE=Europe/Moscow

# ── Cron (обязательно для напоминаний) ─────────────────────────────
# Секрет для защиты эндпойнта /api/cron/send-reminders.
# Любая длинная случайная строка. Vercel Cron передаёт её в заголовке.
CRON_SECRET=change-me-to-a-long-random-string

# ── Telegram (опционально) ─────────────────────────────────────────
# Токен бота из @BotFather. Если не задан — telegram-напоминания
# просто логируются в консоль и помечаются отправленными.
TELEGRAM_BOT_TOKEN=

# ── Email через Resend (опционально) ───────────────────────────────
# API-ключ из resend.com. Если не задан — email-напоминания
# логируются в консоль и помечаются отправленными.
RESEND_API_KEY=
EMAIL_FROM=Запись <onboarding@resend.dev>
